# Salesforce credentials for aisc_salesforce
# Copy to .env for development: cp .env.example .env
# Do not commit .env: it contains sensitive credentials.
SF_CLIENT_ID=
SF_CLIENT_SECRET=
# Optional: Salesforce org URL or full OAuth token endpoint. The production
# default is https://login.salesforce.com/services/oauth2/token.
SF_LOGIN_URL=
